{
  "name": "sj-store-pro",
  "version": "1.0.7",
  "description": "SJ STORE Pro - نظام إدارة محل الهواتف",
  "main": "main.js",
  "author": "SJ STORE",
  "license": "MIT",
  "scripts": {
    "postinstall": "electron-builder install-app-deps",
    "rebuild:native": "electron-builder install-app-deps",
    "start": "electron .",
    "build": "electron-builder --win --x64",
    "release": "electron-builder --win --x64 --publish always"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.sjstore.pro",
    "productName": "SJ STORE Pro",
    "copyright": "SJ STORE 2024",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "icon.ico",
      "publish": [
        {
          "provider": "github",
          "owner": "hikehike0101-collab",
          "repo": "SJ-STORE",
          "releaseType": "release"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "SJ STORE Pro",
      "runAfterFinish": true
    },
    "files": [
      "main.js",
      "preload.js",
      "sqlite-service.js",
      "package.json",
      "index.html",
      "icon.ico",
      "icon.png",
      "logo.png",
      "assets/**",
      "config/**",
      "css/**",
      "js/**",
      "libs/**"
    ],
    "compression": "maximum",
    "asar": true,
    "asarUnpack": [
      "libs/**",
      "node_modules/better-sqlite3/**"
    ],
    "electronVersion": "28.3.3"
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "electron-updater": "^6.8.3",
    "pdfjs-dist": "^5.6.205"
  }
}
